    "google",
    "bluesky"
  ],
  "features": [
    "List connected social media accounts",
    "Create, schedule, queue, or draft posts",
    "Multi-platform posting in one command",
    "Platform-specific settings (reels, stories, shorts, etc.)",
    "Time-series analytics",
    "Per-post performance metrics",
    "Aggregated KPIs",
    "Audience demographics"
  ],
  "setup": {
    "envVars": [
      {
        "name": "SIMPLIFIED_API_KEY",
